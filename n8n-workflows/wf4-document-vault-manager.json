        "jsonBody": "={\n  \"action\": \"get_document\",\n  \"data\": {\n    \"document_id\": \"{{ $('Fetch Documents Webhook').item.json.document_id }}\",\n    \"org_id\": \"{{ $('Fetch Documents Webhook').item.json.org_id }}\"\n  }\n}",
        "options": {}
      },
      "id": "a1b2c3d4-0001-4000-8000-000000000012",
      "name": "Get Single Document",
