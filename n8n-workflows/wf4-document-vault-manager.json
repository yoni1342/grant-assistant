        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"action\": \"get_document_url\",\n  \"data\": {\n    \"document_id\": \"{{ $('Document Upload Webhook').item.json.document_id }}\"\n  }\n}",
        "options": {}
      },
      "id": "a1b2c3d4-0001-4000-8000-000000000003",
