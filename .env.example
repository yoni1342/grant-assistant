NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
N8N_WEBHOOK_URL=https://n8n.thebrownmine.com/webhook-test
N8N_WEBHOOK_SECRET=your-webhook-secret

# Support-request Slack notifier (n8n "Support Request Notifier" workflow)
N8N_SUPPORT_NOTIFIER_URL=https://n8n.thebrownmine.com/webhook/support-request-notify
N8N_SUPPORT_NOTIFIER_SECRET=your-support-notifier-secret

# AWS SES Configuration
AWS_SES_REGION=us-east-1
AWS_SES_FROM_EMAIL=noreply@fundory.ai
AWS_SES_FROM_NAME=Fundory
AWS_SES_REPLY_TO_EMAIL=support@fundory.ai

# AWS Credentials (for local development only)
# Production uses ECS task role
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# Stripe Configuration
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PROFESSIONAL_PRICE_ID=price_...            # monthly
STRIPE_PROFESSIONAL_QUARTERLY_PRICE_ID=price_...  # 3-month, 10% off
STRIPE_PROFESSIONAL_ANNUAL_PRICE_ID=price_...     # 12-month, 30% off
STRIPE_AGENCY_PRICE_ID=price_...                  # monthly
STRIPE_AGENCY_QUARTERLY_PRICE_ID=price_...        # 3-month, 10% off
STRIPE_AGENCY_ANNUAL_PRICE_ID=price_...           # 12-month, 30% off
STRIPE_WEBHOOK_SECRET=whsec_...

# Microsoft Clarity
NEXT_PUBLIC_CLARITY_PROJECT_ID=your-clarity-project-id

# Sentry Configuration
NEXT_PUBLIC_SENTRY_DSN=https://your-key@your-sentry-host/project-id
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=your-sentry-project
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# Cron auth — bearer token expected on /api/cron/* routes
CRON_SECRET=your-random-cron-secret

# Daily Instagram post generator (/api/cron/daily-ig-post)
# Uses claude-opus-4-7 via the Anthropic SDK
ANTHROPIC_API_KEY=sk-ant-...
# Renderer hits localhost by default; override only if running on another host
IG_RENDER_BASE_URL=http://localhost:3002
# System Chrome path used by puppeteer-core
CHROME_PATH=/usr/bin/google-chrome
